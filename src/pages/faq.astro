---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { SITE } from "../lib/blog-data.js";

const faqs = [
  {
    question: "How does it work?",
    answer: "Each month we pick a cookbook. You choose a recipe, make it at home, and bring it to share at our gathering. Everyone signs up for a different dish so the table ends up with a full spread from the same book — no duplicates, lots of variety. You can find the recipe sign-up index on our RSVP page once you register."
  },
  {
    question: "What do I need to bring?",
    answer: "A homemade dish from the featured cookbook, your own plate and cutlery (we try to keep things sustainable), anything needed for safe food transport, a container for leftovers, napkins and wet wipes if needed, and an appetite and good energy. You're also welcome to bring a drink you'd like to share, though it's optional."
  },
  {
    question: "Where can I get the recipes?",
    answer: "While there's no pressure to buy the cookbook, we encourage supporting the authors if you're able. You can also check it out on Libby, borrow from a friend, or browse it at your local bookstore. If you're having trouble accessing the recipes, feel free to reach out and we'll help."
  },
  {
    question: "Can I join if I have a food allergy?",
    answer: "Yes, absolutely. If you have any food allergies or require special dietary accommodations, please contact us via DM on Instagram (@sautesundays.to) before the event. Since it is a public food-sharing event with home-cooked dishes, we encourage you to take any necessary precautions — but we're always happy to help where we can."
  },
  {
    question: "Is it free?",
    answer: "Yes — Sauté Sundays is completely free to attend. The only cost is the groceries for the dish you make and bring to share. No ticket, no cover charge, no catch."
  },
  {
    question: "How do I get early access to RSVP?",
    answer: "Events sell out fast — usually within a few hours of opening. Early access goes to our newsletter subscribers and WhatsApp community first. Sign up at the link below to make sure you don't miss out."
  },
  {
    question: "Where are events held?",
    answer: "We host monthly in downtown Toronto. It's a warm, with capacity for 35 people or more — big enough to have a full table, small enough to actually meet everyone."
  },
  {
    question: "How do I suggest a cookbook?",
    answer: "Reply to any of our newsletters with your suggestion, or send us a DM on Instagram. We love hearing what people want to cook from — it directly shapes what we pick each month."
  },
];
---

<BaseLayout
  title={`FAQ - ${SITE.name}`}
  description="Frequently asked questions about Sauté Sundays — Toronto's cookbook club. How it works, what to bring, how to RSVP, and more."
  canonical="/faq"
>
  <div class="mx-auto max-w-3xl px-5 py-12">
    <Breadcrumbs items={[{ label: "Home", to: "/" }, { label: "FAQ" }]} />

    <header class="mt-6 mb-12">
      <div class="text-xs font-medium uppercase tracking-[0.2em] text-primary">FAQ</div>
      <h1 class="mt-2 font-serif text-5xl font-semibold leading-[1.05]">
        Questions & answers.
      </h1>
      <p class="mt-4 max-w-xl text-muted-foreground">
        Everything you need to know before your first Sauté Sundays. Still have a question? Email us at <a href="mailto:sautesundays.to@gmail.com" class="text-primary hover:underline">sautesundays.to@gmail.com</a>.
      </p>
    </header>

    <div class="divide-y divide-border">
      {faqs.map((faq) => (
        <details class="group py-6">
          <summary class="flex cursor-pointer items-center justify-between gap-4 font-serif text-xl font-semibold leading-snug marker:content-none hover:text-primary">
            {faq.question}
            <span class="shrink-0 text-muted-foreground transition-transform group-open:rotate-45">+</span>
          </summary>
          <p class="mt-4 text-muted-foreground leading-relaxed">
            {faq.answer}
          </p>
        </details>
      ))}
    </div>

    <div class="mt-16 rounded-lg border border-border bg-muted/40 px-8 py-10 text-center">
      <p class="font-serif text-2xl font-semibold">Ready to join?</p>
      <p class="mt-2 text-muted-foreground">Sign up for early access and be the first to know when spots open.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-4">
        <a href="/contact" class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground hover:opacity-90 transition-opacity">
          Join the community
        </a>
        <a href="https://lu.ma/sautesundaysto" class="inline-flex items-center gap-2 rounded-full border border-border px-6 py-3 text-sm font-semibold hover:bg-muted transition-colors">
          RSVP on Luma
        </a>
      </div>
    </div>
  </div>
</BaseLayout>