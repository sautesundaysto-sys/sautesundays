---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { SITE } from "../lib/blog-data.js";
---

<BaseLayout
  title={`Gallery - ${SITE.name}`}
  description="Photos from Sauté Sundays — Toronto's cookbook club. A year of monthly potluck gatherings, one cookbook at a time."
  canonical="/gallery"
>
  <div class="mx-auto max-w-6xl px-5 py-12">
    <Breadcrumbs items={[{ label: "Home", to: "/" }, { label: "Gallery" }]} />

    <header class="mt-6 mb-12">
      <div class="text-xs font-medium uppercase tracking-[0.2em] text-primary">Gallery</div>
      <h1 class="mt-2 font-serif text-5xl font-semibold leading-[1.05]">
        A year of good tables.
      </h1>
      <p class="mt-4 max-w-xl text-muted-foreground">
        Every month, one cookbook, thirty-five people, and a table full of dishes nobody planned together.
      </p>
    </header>

    <div class="rounded-lg border border-border bg-muted/40 px-8 py-16 text-center">
      <p class="font-serif text-2xl font-semibold">See every night on Instagram</p>
      <p class="mt-3 text-muted-foreground max-w-md mx-auto">
        All our event photos, dish shots, and behind-the-scenes moments live on Instagram — a full year of tables, cuisines, and community.
      </p>
      
        href="https://www.instagram.com/sautesundays.to/"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground hover:opacity-90 transition-opacity"
      >
        @sautesundays.to ↗
      </a>
    </div>

    <section class="mt-16">
      <h2 class="font-serif text-2xl font-semibold mb-8">Past Events</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <a href="/blog" class="group rounded-lg border border-border p-6 hover:bg-muted transition-colors">
          <div class="text-xs font-medium uppercase tracking-wider text-primary mb-2">Event Recaps</div>
          <div class="font-serif text-lg font-semibold group-hover:text-primary">Read all past event recaps →</div>
          <p class="mt-2 text-sm text-muted-foreground">Greek, Moroccan, Caribbean, Vietnamese and more — one cookbook at a time.</p>
        </a>
      </div>
    </section>

  </div>
</BaseLayout>