---
const { compact = false } = Astro.props;
---

{
  compact ? (
    <div>
      <div class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Stay in the loop</div>
      <p class="mt-2 text-sm text-muted-foreground">Sign up for early access to events and updates.</p>
      
        href="/contact"
        class="mt-3 inline-flex items-center gap-2 rounded-full bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground hover:opacity-90 transition-opacity"
      >
        Join the community
      </a>
    </div>
  ) : (
    <section class="border-t border-border/60 pt-16 pb-10">
      <div class="mx-auto max-w-2xl px-5 text-center">
        <h2 class="font-serif text-3xl font-semibold sm:text-4xl">Join the Sauté Sundays community.</h2>
        <p class="mt-3 text-muted-foreground">
          Sign up for early access to events, cookbook announcements, and monthly updates. Spots fill fast — subscribers get first dibs.
        </p>
        <div class="mt-6">
          
            <a href="/contact"
            class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground hover:opacity-90 transition-opacity"
          >
            Sign up for early access
          </a>
        </div>
        <p class="mt-3 text-xs text-muted-foreground">Free. Just your email. Unsubscribe anytime.</p>
      </div>
    </section>
  )
}